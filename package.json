{
  "name": "dtorch-demo",
  "version": "0.1.0",
  "private": true,
  "description": "DT Orch SDK demo: CLI scripts + small React console (CRUD, queue cron, notifications)",
  "type": "commonjs",
  "scripts": {
    "build": "tsc",
    "validate": "tsx src/validate.ts",
    "migrate:sql": "tsx src/print-migration.ts",
    "db:demo": "tsx src/db-demo.ts",
    "storage": "tsx src/storage-demo.ts",
    "notify": "tsx src/notify-demo.ts",
    "subscribe": "tsx src/subscribe-demo.ts",
    "cron": "tsx src/cron-demo.ts",
    "queue": "tsx src/queue-demo.ts",
    "demo": "tsx src/run-all.ts",
    "server": "tsx server/index.ts",
    "web": "vite --config web/vite.config.ts",
    "app": "concurrently -k -n api,web -c green,cyan \"npm run server\" \"npm run web\""
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@dtorch/sdk": "file:../python/etl-deployment/sdk/javascript",
    "centrifuge": "^5.2.2",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "node-cron": "^4.6.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^26.1.1",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^9.2.0",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^7.0.4"
  }
}
